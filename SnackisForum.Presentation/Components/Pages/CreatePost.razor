@page "/createpost/{SubCategoryId:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Application.Interfaces
@using Domain.Models
@using System.ComponentModel.DataAnnotations
@inject IPostServices PostService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Skapa inlägg</PageTitle>

<div class="container mt-4">
    <h2>Skapa nytt inlägg</h2>
    <hr />
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    <EditForm Model="postModel" OnValidSubmit="CreatePostAsync" FormName="createpost">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label>Titel</label>
            <InputText class="form-control" @bind-Value="postModel.Title" />
        </div>
        <div class="mb-3">
            <label>Text</label>
            <InputTextArea class="form-control" @bind-Value="postModel.Description" />
        </div>
        <button class="btn btn-primary">Publicera</button>
        <a class="btn btn-secondary ms-2" href="/subcategory/@SubCategoryId">Avbryt</a>
    </EditForm>
</div>

