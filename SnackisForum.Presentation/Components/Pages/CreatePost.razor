@page "/createpost/{SubCategoryId:int}"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Application.Interfaces
@using Domain.Models
@using System.ComponentModel.DataAnnotations
@inject IPostServices PostService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager Navigation

<PageTitle>Skapa inlägg</PageTitle>

<div class="container mt-4">
    <h2>Skapa nytt inlägg</h2>
    <hr />
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    <EditForm Model="postModel" OnValidSubmit="CreatePostAsync" FormName="createpost">
        <DataAnnotationsValidator />
        <div class="mb-3">
            <label>Titel</label>
            <InputText class="form-control" @bind-Value="postModel.Title" />
        </div>
        <div class="mb-3">
            <label>Text</label>
            <InputTextArea class="form-control" @bind-Value="postModel.Description" />
        </div>
        <button class="btn btn-primary">Publicera</button>
        <a class="btn btn-secondary ms-2" href="/subcategory/@SubCategoryId">Avbryt</a>
    </EditForm>
</div>

@code {
    [Parameter]
    public int SubCategoryId { get; set; }

    private string errorMessage = "";

    [SupplyParameterFromForm]
    private PostInput postModel { get; set; } = new();

    private async Task CreatePostAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user == null)
        {
            errorMessage = "Du måste vara inloggad.";
            return;
        }

        var post = new Post
        {
            Title = postModel.Title,
            Description = postModel.Description,
            UserId = user.Id,
            DatePublication = DateTime.Now,
            SubCategoryId = SubCategoryId
        };

        await PostService.AddAsync(post);
        Navigation.NavigateTo($"/subcategory/{SubCategoryId}");
    }

    public class PostInput
    {
        [Required]
        public string Title { get; set; } = "";
        [Required]
        public string Description { get; set; } = "";
    }
}