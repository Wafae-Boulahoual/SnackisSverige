@page "/post/{Id:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Application.Interfaces
@using Domain.Models
@using System.ComponentModel.DataAnnotations
@inject IPostServices PostService
@inject ICommentServices CommentService
@inject IReportServices ReportService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>@post?.Title</PageTitle>
<ForumHeader />
<div class="container mt-4">

    @if (post == null)
    {
        <p>Laddar...</p>
    }
    else
    {
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item"><a href="/subcategory/@post.SubCategoryId">@post.SubCategory?.Title</a></li>
                <li class="breadcrumb-item active">@post.Title</li>
            </ol>
        </nav>
        <div class="card mb-4 shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-start">
                <div class="d-flex align-items-center gap-3">
                    @if (!string.IsNullOrEmpty(post.User?.ImagePath))
                    {
                        <img src="@post.User.ImagePath" class="rounded-circle"
                             style="width:45px; height:45px; object-fit:cover;" />
                    }
                    else
                    {
                        <span style="font-size:2rem;">👤</span>
                    }
                    <div>
                        <h2>@post.Title</h2>
                        <p class="text-muted small">
                             @post.User?.FirstName @post.User?.LastName —
                             @post.DatePublication.ToString("yyyy-MM-dd")
                        </p>
                    </div>
                </div>
                @if (IsAdmin)
                {
                    <button class="btn btn-sm btn-danger" @onclick="DeletePost">
                         Ta bort inlägg
                    </button>
                }
            </div>
            <div class="card-body">
                <p>@post.Description</p>
                <AuthorizeView Context="authContext">
                    <Authorized>
                        <button class="btn btn-sm btn-outline-danger"
                                @onclick="() => ReportPost(post)">
                             Anmäl inlägg
                        </button>
                    </Authorized>
                </AuthorizeView>
                @if (reportSuccess)
                {
                    <div class="alert alert-success mt-2">Anmälan skickad!</div>
                }
            </div>
        </div>

        <h4>Kommentarer</h4>
        <hr />

        @if (comments == null || comments.Count == 0)
        {
            <div class="alert alert-info">Inga kommentarer finns ännu.</div>
        }
        else
        {
            @foreach (var comment in comments)
            {
                <div class="card mb-2 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            @if (!string.IsNullOrEmpty(comment.User?.ImagePath))
                            {
                                <img src="@comment.User.ImagePath" class="rounded-circle"
                                     style="width:40px; height:40px; object-fit:cover;" />
                            }
                            else
                            {
                                <span style="font-size:1.5rem;">👤</span>
                            }
                            <p class="text-muted small mb-0">
                                 @comment.User?.FirstName @comment.User?.LastName —
                                 @comment.DateAnswer.ToString("yyyy-MM-dd")
                            </p>
                        </div>
                        <p>@comment.Text</p>
                        <div class="d-flex gap-2">
                            <AuthorizeView Context="authContext">
                                <Authorized>
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => ReportComment(comment)">
                                         Anmäl kommentar
                                    </button>
                                </Authorized>
                            </AuthorizeView>
                            @if (IsAdmin)
                            {
                                <button class="btn btn-sm btn-danger"
                                        @onclick="() => DeleteComment(comment.Id)">
                                     Ta bort
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        }

        <hr />
        <h5>Skriv en kommentar</h5>

        <AuthorizeView Context="authContext">
            <Authorized>
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">@errorMessage</div>
                }
                <EditForm Model="commentModel" OnValidSubmit="AddComment" FormName="addcomment">
                    <DataAnnotationsValidator />
                    <div class="mb-3">
                        <InputTextArea class="form-control" rows="3"
                                       @bind-Value="commentModel.Text"
                                       placeholder="Skriv din kommentar här..." />
                        <ValidationMessage For="() => commentModel.Text" class="text-danger" />
                    </div>
                    <button class="btn btn-primary">Skicka</button>
                </EditForm>
            </Authorized>
            <NotAuthorized>
                <div class="alert alert-info">
                    <a href="/Account/Login">Logga in</a> för att kommentera.
                </div>
            </NotAuthorized>
        </AuthorizeView>
    }
</div>

