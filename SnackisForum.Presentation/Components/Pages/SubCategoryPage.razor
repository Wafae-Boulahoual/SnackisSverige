@page "/subcategory/{Id:int}"
@rendermode InteractiveServer
@using Application.Interfaces
@using Domain.Models
@inject ISubCategoryServices SubCategoryService
@inject IPostServices PostService

<PageTitle>@subCategory?.Title</PageTitle>

<div class="container mt-4">

    @if (subCategory != null)
    {
        <h2>@subCategory.Title</h2>
        <p class="text-muted">@subCategory.Description</p>
    }

    <hr />

    @if (posts == null)
    {
        <p>Laddar inlägg...</p>
    }
    else if (posts.Count == 0)
    {
        <div class="alert alert-info">
            Inga inlägg finns ännu.
        </div>
    }
    else
    {
        @foreach (var post in posts)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">
                        <a href="/post/@post.Id" class="text-decoration-none fw-bold">
                            @post.Title
                        </a>
                    </h5>
                    <p class="text-muted small">
                        ✍️ @post.User?.FirstName @post.User?.LastName —
                        📅 @post.DatePublication.ToString("yyyy-MM-dd")
                    </p>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int Id { get; set; }

    private SubCategory? subCategory;
    private List<Post>? posts;

    protected override async Task OnInitializedAsync()
    {
        subCategory = await SubCategoryService.GetByIdAsync(Id);
        posts = await PostService.GetBySubCategoryIdAsync(Id);
    }
}