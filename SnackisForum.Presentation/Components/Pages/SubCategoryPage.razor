@page "/subcategory/{Id:int}"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization
@using Application.Interfaces
@using Domain.Models
@inject ISubCategoryServices SubCategoryService
@inject IPostServices PostService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>@subCategory?.Title</PageTitle>
<ForumHeader />
<div class="container mt-4">
    @if (subCategory != null)
    {
        <h2>@subCategory.Title</h2>
        <p class="text-muted">@subCategory.Description</p>
    }
    <hr />

    <AuthorizeView>
        <Authorized>
            <a href="/createpost/@Id" class="btn btn-success mb-3">
                 Skapa nytt inlägg
            </a>
        </Authorized>
        <NotAuthorized>
            <div class="alert alert-info">
                <a href="/Account/Login">Logga in</a> för att skapa ett inlägg.
            </div>
        </NotAuthorized>
    </AuthorizeView>

    @if (posts == null)
    {
        <p>Laddar inlägg...</p>
    }
    else if (posts.Count == 0)
    {
        <div class="alert alert-info">Inga inlägg finns ännu.</div>
    }
    else
    {
        @foreach (var post in posts)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-body d-flex justify-content-between align-items-start">
                    <div>
                        <h5 class="card-title">
                            <a href="/post/@post.Id" class="text-decoration-none fw-bold">
                                @post.Title
                            </a>
                        </h5>
                        <p class="text-muted small">
                             @post.User?.FirstName @post.User?.LastName —
                             @post.DatePublication.ToString("yyyy-MM-dd")
                        </p>
                    </div>
                    @if (IsAdmin)
                    {
                        <button class="btn btn-sm btn-danger"
                                @onclick="() => DeletePost(post.Id)">
                             Ta bort
                        </button>
                    }
                </div>
            </div>
        }
    }
</div>

